# GitHub OAuth (create at github.com/settings/applications/new)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# NextAuth secret (generate: openssl rand -base64 32)
AUTH_SECRET=

# Your GitHub username — only this user can log in
GITHUB_USERNAME=

# GitHub PAT with repo scope (for reading/writing iso-life)
# Create at github.com/settings/tokens
GITHUB_TOKEN=

# iso-life repo details
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=iso-life

# App URL (set to your Vercel URL in production)
NEXTAUTH_URL=http://localhost:3000
